{
  "schemaVersion": 1,
  "id": "yes_steve_model",
  "version": "${version}",
  "name": "Fox Model Loader",
  "description": "Originally based on OpenYSM.",
  "authors": ["Micaftic"],
  "contact": {
    "homepage": "https://github.com/sdf123098/Fox-Model-Loader",
    "sources": "https://github.com/sdf123098/Fox-Model-Loader",
    "issues": "https://github.com/sdf123098/Fox-Model-Loader/issues"
  },
  "license": "MIT",
  "icon": "assets/yes_steve_model/texture/mod_icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.elfmcys.yesstevemodel.fabric.YesSteveModelFabric"
    ],
    "client": [
      "com.elfmcys.yesstevemodel.fabric.client.YesSteveModelFabricClient"
    ],
    "cardinal-components-entity": [
      "com.elfmcys.yesstevemodel.fabric.YsmComponents"
    ]
  },
  "mixins": [
    "yes_steve_model.mixins.json",
    "yes_steve_model_fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.10",
    "minecraft": ">=26.1",
    "java": ">=25",
    "fabric-api": "*",
    "forgeconfigapiport": "*"
  },
  "suggests": {
    "another-mod": "*"
  },
  "custom": {
    "cardinal-components": [
      "yes_steve_model:star_models",
      "yes_steve_model:auth_models",
      "yes_steve_model:model_info",
      "yes_steve_model:projectile_model",
      "yes_steve_model:vehicle_model"
    ]
  }
}
